{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "RPC Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(deriva_rpc_total[5m])",
          "legendFormat": "{{method}} ({{status}})"
        }
      ]
    },
    {
      "title": "RPC Latency (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(deriva_rpc_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(deriva_rpc_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(deriva_rpc_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "deriva_cache_hit_rate",
          "legendFormat": "Hit Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 0.5, "color": "yellow" },
              { "value": 0.8, "color": "green" }
            ]
          },
          "unit": "percentunit"
        }
      }
    },
    {
      "title": "Cache Size",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "deriva_cache_size_bytes",
          "legendFormat": "Size"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Active Materializations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "deriva_materialize_active",
          "legendFormat": "Active"
        }
      ]
    },
    {
      "title": "Compute Duration by Function",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(deriva_compute_duration_seconds_bucket[5m]))",
          "legendFormat": "{{function}} p99"
        }
      ]
    },
    {
      "title": "Materialization Outcomes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(deriva_materialize_total[5m])",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "title": "Verification",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "deriva_verification_failure_rate",
          "legendFormat": "Failure Rate"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["deriva"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Deriva Dashboard",
  "uid": "deriva-main"
}
